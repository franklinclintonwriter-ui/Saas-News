# =============================================================================
# Phulpur24 — PRODUCTION env template
# Copy to .env.production and populate via your secrets manager.
# NEVER commit a populated version of this file.
# =============================================================================

# ---- Runtime -------------------------------------------------------------
NODE_ENV="production"
API_PORT="4102"
API_PUBLIC_URL="https://tznssjmavvzrnqmmdmty.supabase.co/functions/v1/public-api"
PUBLIC_SITE_URL="https://www.phulpur.net"
API_MAX_JSON_BODY="15mb"
MEDIA_UPLOAD_MAX_BYTES="26214400"

# ---- CORS allowlist (comma-separated, no trailing slash) -----------------
# localhost / 127.0.0.1 entries will be rejected at boot in production.
CORS_ORIGIN="https://www.phulpur.net,https://admin.phulpur.net"

# ---- Secrets (each >= 32 random chars; rotate periodically) --------------
# Generate with:  openssl rand -base64 48
JWT_SECRET=""
JWT_REFRESH_SECRET=""
INTEGRATION_SECRET_KEY=""
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_DAYS="30"

# ---- First-boot admin bootstrap (used ONLY by prisma/seed.ts) ------------
# If both are unset, the seed is skipped. Remove once the admin exists.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Administrator"

# ---- Database (Supabase Postgres — project "Megagine", ap-northeast-1) ---
# Transaction pooler (port 6543) for runtime traffic:
DATABASE_URL="postgresql://postgres.tznssjmavvzrnqmmdmty:DB_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) used by migrations / prisma migrate deploy:
DIRECT_URL="postgresql://postgres.tznssjmavvzrnqmmdmty:DB_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ---- Supabase (Auth + Storage) -------------------------------------------
SUPABASE_URL="https://tznssjmavvzrnqmmdmty.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_MZugK2WkoPdxs3K4QLPs7w_SPNqLEp3"
SUPABASE_SERVICE_ROLE_KEY=""    # SERVER-ONLY; bypasses RLS. Retrieve from dashboard → Settings → API.

# Your project signs JWTs with ES256 (asymmetric). The API fetches the
# public keys from the JWKS discovery URL below and caches them for 10min.
# You do NOT need SUPABASE_JWT_SECRET unless you have legacy HS256 tokens.
SUPABASE_JWKS_URL="https://tznssjmavvzrnqmmdmty.supabase.co/auth/v1/.well-known/jwks.json"
# SUPABASE_JWT_SECRET=""        # Only set if HS256 tokens are still in circulation.

# ---- Media storage (Supabase Storage) ------------------------------------
SUPABASE_MEDIA_BUCKET="article-media"
SUPABASE_AVATAR_BUCKET="avatars"

# ---- Transactional mail (Resend) -----------------------------------------
RESEND_API_KEY=""
RESEND_FROM="Phulpur24 <hello@phulpur.net>"
RESEND_NEWSLETTER_FROM="Phulpur24 <newsletter@phulpur.net>"

# ---- Error tracking (Sentry) ---------------------------------------------
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"
SENTRY_TRACES_SAMPLE_RATE="0.1"

# ---- Analytics (Plausible, public surface only) --------------------------
PLAUSIBLE_DOMAIN="www.phulpur.net"
PLAUSIBLE_SCRIPT="https://plausible.io/js/script.js"

# ---- AI providers (optional) ---------------------------------------------
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-3-5-haiku-latest"
# GOOGLE_AI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"
# OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="openai/gpt-4o-mini"
# OPENROUTER_SITE_URL set automatically from PUBLIC_SITE_URL if unset
# OPENROUTER_APP_NAME=""
# AI_REQUEST_TIMEOUT_MS="120000"

# ---- Legacy R2 media (only if you postpone Supabase Storage migration) ---
# CLOUDFLARE_ACCOUNT_ID=""
# R2_BUCKET=""
# R2_ENDPOINT=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_PUBLIC_BASE_URL=""
# R2_OBJECT_PREFIX="media"

# =============================================================================
# Frontend (Vite) — PRODUCTION env
# Build-time only; anything with VITE_ prefix is inlined into the JS bundle
# and visible in the browser. Never put service-role keys here.
# =============================================================================
VITE_API_BASE_URL="https://tznssjmavvzrnqmmdmty.supabase.co/functions/v1/public-api"
VITE_PUBLIC_SITE_URL="https://www.phulpur.net"
VITE_SUPABASE_URL="https://tznssjmavvzrnqmmdmty.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_MZugK2WkoPdxs3K4QLPs7w_SPNqLEp3"
VITE_SENTRY_DSN=""
VITE_PLAUSIBLE_DOMAIN="www.phulpur.net"

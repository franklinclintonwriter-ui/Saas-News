NODE_ENV="production"
DATABASE_URL="file:./data/phulpur24.db"
API_PORT="4102"
API_PUBLIC_URL="https://api.your-domain.com/api"
API_MAX_JSON_BODY="15mb"
MEDIA_UPLOAD_MAX_BYTES="26214400"
CORS_ORIGIN="https://your-cloudflare-pages-domain.pages.dev,https://your-domain.com"
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
JWT_REFRESH_SECRET="replace-with-another-long-random-secret-at-least-32-characters"
INTEGRATION_SECRET_KEY="replace-with-a-third-long-random-secret-at-least-32-characters"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_DAYS="30"
ADMIN_EMAIL="admin@phulpur24.com"
ADMIN_PASSWORD="change-this-before-production"
ADMIN_NAME="Phulpur24 Admin"

CLOUDFLARE_ACCOUNT_ID=""
R2_BUCKET="phulpur"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_BASE_URL=""
R2_OBJECT_PREFIX="media"
